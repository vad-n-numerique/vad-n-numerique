---
import Card from '../ui/Card.astro';
import SectionTitle from '../ui/SectionTitle.astro';

const domaines = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="2" y1="9" x2="22" y2="9"/><line x1="8" y1="4" x2="8" y2="9"/></svg>`,
    title: 'Applications',
    description:
      "Développement d'applications web et mobiles. Interfaces modernes, architectures solides, déploiement multiplateforme.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: 'Logiciels',
    description:
      "Conception de logiciels desktop et d'outils métiers. Solutions pensées pour durer, maintenables et adaptées aux usages réels.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>`,
    title: 'Jeux vidéo',
    description:
      "Développement de jeux 2D et 3D pour PC, mobile ou web. De la conception du gameplay à l'intégration des assets.",
  },
];
---

<section class="py-20 md:py-28 bg-bg border-b border-slate-200/60">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionTitle
      title="Nos activités"
      subtitle="Trois domaines de développement, une même exigence technique."
    />
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {domaines.map((domaine) => (
        <div class="fade-in">
          <Card {...domaine} />
        </div>
      ))}
    </div>
  </div>
</section>
