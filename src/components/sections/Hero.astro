---
---

<section class="relative overflow-hidden bg-dark dot-grid text-white pt-14 pb-24 sm:pt-20 sm:pb-36 md:pt-32 md:pb-52">

  <!-- Gradient mesh centré -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Halo principal indigo centré en haut -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/3 w-225 h-150 bg-primary/20 rounded-full blur-3xl"></div>
    <!-- Halo orange bas-gauche -->
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-secondary/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>
    <!-- Halo indigo clair bas-droit -->
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-primary/15 rounded-full blur-2xl translate-y-1/3 translate-x-1/4"></div>
  </div>

  <!-- Ligne de séparation basse -->
  <div class="absolute bottom-0 inset-x-0 h-px bg-linear-to-r from-transparent via-white/10 to-transparent" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center text-center">

      <!-- Logo -->
      <img
        src="/logo.png"
        alt="VAD-N Numérique"
        class="w-56 sm:w-80 md:w-120 h-auto mb-6 drop-shadow-2xl"
        width="480"
        height="160"
      />

      <!-- Nom avec gradient subtil -->
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight mb-5">
        <span class="text-transparent bg-clip-text bg-linear-to-r from-white via-slate-100 to-slate-300">
          VAD-N Numérique
        </span>
      </h1>

      <!-- Séparateur indigo -->
      <div class="flex items-center gap-3 mb-5" aria-hidden="true">
        <div class="w-8 h-px bg-primary/50 rounded-full"></div>
        <div class="w-2 h-2 rounded-full bg-primary"></div>
        <div class="w-8 h-px bg-primary/50 rounded-full"></div>
      </div>

      <!-- Tagline -->
      <p class="text-base md:text-lg text-slate-400 leading-relaxed max-w-md tracking-wide">
        Développement d'applications, de logiciels et de jeux vidéo.
      </p>

    </div>
  </div>
</section>
