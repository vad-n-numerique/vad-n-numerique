---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div
  data-tilt
  class="group relative bg-white rounded-2xl p-7 border border-slate-200/80 shadow-sm transition-shadow duration-300 hover:shadow-xl hover:border-primary/30 overflow-hidden"
  style="transform-style: preserve-3d; will-change: transform;"
>
  <!-- Halo d'accent au hover -->
  <div class="absolute inset-0 bg-linear-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl pointer-events-none" aria-hidden="true"></div>
  <div class="relative">
    <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary/8 text-primary mb-5 transition-all duration-300 group-hover:bg-primary group-hover:text-white group-hover:scale-105">
      <Fragment set:html={icon} />
    </div>
    <h3 class="text-lg font-semibold text-text mb-2">{title}</h3>
    <p class="text-muted leading-relaxed text-sm">{description}</p>
  </div>
</div>

<script>
  const cards = document.querySelectorAll<HTMLElement>('[data-tilt]');

  cards.forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const cx = rect.width / 2;
      const cy = rect.height / 2;
      const rotX = ((y - cy) / cy) * -8;
      const rotY = ((x - cx) / cx) * 8;
      card.style.transform = `perspective(800px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateZ(6px)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transition = 'transform 0.4s ease, box-shadow 0.3s';
      card.style.transform = 'perspective(800px) rotateX(0deg) rotateY(0deg) translateZ(0px)';
      setTimeout(() => { card.style.transition = ''; }, 400);
    });

    card.addEventListener('mouseenter', () => {
      card.style.transition = 'transform 0.1s ease, box-shadow 0.3s';
    });
  });
</script>
