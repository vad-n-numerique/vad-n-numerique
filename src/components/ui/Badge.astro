---
interface Props {
  label: string;
  icon?: string;
}

const { label, icon } = Astro.props;
---

<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-primary/10 text-primary border border-primary/20">
  {icon && <Fragment set:html={icon} />}
  {label}
</span>
